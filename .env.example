# 本地开发环境变量（复制为 .env 后修改）
DEBUG=True
SECRET_KEY=dev-secret-key-change-in-production

# 数据库（开发环境可用 SQLite，注释掉 USE_SQLITE 则使用 PostgreSQL）
USE_SQLITE=True
DB_NAME=apartment_rental
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# JWT
ACCESS_TOKEN_LIFETIME_MINUTES=30
REFRESH_TOKEN_LIFETIME_DAYS=7

# 上传文件
MEDIA_ROOT=./media
MEDIA_URL=/uploads/

# 短信（mock 为开发环境模拟发送）
SMS_PROVIDER=mock

# 管理员初始账号
ADMIN_USERNAME=admin123
ADMIN_PASSWORD=3816832z
